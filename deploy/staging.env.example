ENVIRONMENT=production
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
EMBEDDING_LOCAL_FILES_ONLY=1
RERANKER_LOCAL_FILES_ONLY=1
HF_HOME=/opt/hf-cache
SENTENCE_TRANSFORMERS_HOME=/opt/hf-cache
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
# IMPORTANT (W-V43-11.5 / R-2604-03 mitigation):
# As of this version, the local-provider gate is loopback-only by default.
# `host.docker.internal`, private-LAN, and `*.local`/`*.internal` mDNS all
# require ALLOW_REMOTE_VLLM=1.
#
# THIS EXAMPLE INTENTIONALLY FAILS CLOSED. The shipped pair below
# (`VLLM_URL=http://host.docker.internal:...` + `ALLOW_REMOTE_VLLM=0`)
# is rejected by `get_llm_config()` so that an operator who copies the
# template without reading these notes cannot silently end up with
# `ALLOW_REMOTE_VLLM=1` paired with whatever URL they later swap in
# (e.g. a typo to a public-Internet endpoint). To bring up staging:
#   - If you keep VLLM_URL pointing at host.docker.internal or a private
#     LAN box, set ALLOW_REMOTE_VLLM=1 here AND audit that VLLM_URL is
#     the trusted private endpoint you actually want.
#   - If you switch VLLM_URL to a true loopback target inside the
#     container's netns (e.g. a process running on 127.0.0.1 inside the
#     same container), keep ALLOW_REMOTE_VLLM=0.
VLLM_URL=http://host.docker.internal:8001/v1
ALLOW_REMOTE_VLLM=0
NOTEBOOKLM_API_KEYS=staging-owner:replace-with-real-api-key
