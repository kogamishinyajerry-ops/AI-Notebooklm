{
  "$defs": {
    "ArtifactType": {
      "description": "Valid artifact type identifiers.",
      "enum": [
        "requirement",
        "function",
        "interface",
        "abnormal",
        "glossary_entry",
        "trace_link",
        "mode",
        "transition",
        "guard"
      ],
      "title": "ArtifactType",
      "type": "string"
    },
    "LifecycleStatus": {
      "description": "Artifact lifecycle status.",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "withdrawn"
      ],
      "title": "LifecycleStatus",
      "type": "string"
    },
    "Provenance": {
      "description": "Tracks how artifact content was produced and its review state.\n\nThis is central to APLH's knowledge governance: every piece of content\nmust declare its origin and confidence level so that reviewers can\nassess trustworthiness.",
      "properties": {
        "source_type": {
          "$ref": "#/$defs/ProvenanceSourceType",
          "description": "How this content was produced"
        },
        "source_refs": {
          "description": "List of source document references (document IDs, URLs, etc.)",
          "items": {
            "type": "string"
          },
          "title": "Source Refs",
          "type": "array"
        },
        "method": {
          "default": "",
          "description": "Description of the production method (e.g., 'extracted by Gemini 3.1 Pro from CCAR-33 §33.28')",
          "title": "Method",
          "type": "string"
        },
        "confidence": {
          "default": 0.5,
          "description": "Confidence level 0.0–1.0",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "reviewed_by": {
          "default": "",
          "description": "Reviewer identity (empty if not yet reviewed)",
          "title": "Reviewed By",
          "type": "string"
        },
        "review_date": {
          "default": "",
          "description": "ISO date of review (empty if not yet reviewed)",
          "pattern": "^(|[0-9]{4}-[0-9]{2}-[0-9]{2}(T[0-9]{2}:[0-9]{2}:[0-9]{2}(Z|[\\+\\-][0-9]{2}:[0-9]{2})?)?)$",
          "title": "Review Date",
          "type": "string"
        }
      },
      "required": [
        "source_type"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "ProvenanceSourceType": {
      "description": "How the artifact content was produced.",
      "enum": [
        "human_authored",
        "ai_extracted",
        "ai_inferred",
        "mixed",
        "reference"
      ],
      "title": "ProvenanceSourceType",
      "type": "string"
    },
    "ReviewStatus": {
      "description": "Review workflow status.",
      "enum": [
        "draft",
        "in_review",
        "reviewed",
        "frozen",
        "rejected"
      ],
      "title": "ReviewStatus",
      "type": "string"
    },
    "SignalDefinition": {
      "description": "A single signal within an interface.",
      "properties": {
        "name": {
          "description": "Signal name",
          "title": "Name",
          "type": "string"
        },
        "direction": {
          "default": "",
          "description": "Signal direction: 'in', 'out', or 'bidirectional'",
          "title": "Direction",
          "type": "string"
        },
        "data_type": {
          "default": "",
          "description": "Data type (e.g., 'float32', 'boolean', 'enum', 'integer')",
          "title": "Data Type",
          "type": "string"
        },
        "unit": {
          "default": "",
          "description": "Engineering unit (e.g., 'rpm', 'degC', '%', 'psi')",
          "title": "Unit",
          "type": "string"
        },
        "valid_range": {
          "default": "",
          "description": "Valid range description (e.g., '0–120%', '−40–800 degC')",
          "title": "Valid Range",
          "type": "string"
        },
        "description": {
          "default": "",
          "description": "Brief description of what this signal represents",
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "SignalDefinition",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Logical interface specification for propulsion control system.",
  "properties": {
    "id": {
      "description": "Unique artifact ID (e.g., REQ-0001)",
      "title": "Id",
      "type": "string"
    },
    "artifact_type": {
      "$ref": "#/$defs/ArtifactType",
      "default": "interface",
      "description": "Must be 'interface'"
    },
    "version": {
      "default": "0.1.0",
      "description": "Semantic version of this artifact",
      "title": "Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/LifecycleStatus",
      "default": "draft",
      "description": "Lifecycle status"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance",
      "description": "Content provenance and confidence metadata"
    },
    "review_status": {
      "$ref": "#/$defs/ReviewStatus",
      "default": "draft",
      "description": "Review workflow status"
    },
    "tags": {
      "description": "Free-form tags for filtering/grouping",
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "created_at": {
      "description": "ISO 8601 creation timestamp",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[\\+\\-][0-9]{2}:[0-9]{2})?$",
      "title": "Created At",
      "type": "string"
    },
    "updated_at": {
      "description": "ISO 8601 last-updated timestamp",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[\\+\\-][0-9]{2}:[0-9]{2})?$",
      "title": "Updated At",
      "type": "string"
    },
    "notes": {
      "default": "",
      "description": "Free-text notes, assumptions, open questions",
      "title": "Notes",
      "type": "string"
    },
    "name": {
      "description": "Interface name",
      "title": "Name",
      "type": "string"
    },
    "interface_type": {
      "default": "",
      "description": "Type of interface (e.g., 'data_bus', 'discrete', 'analog', 'software_api')",
      "title": "Interface Type",
      "type": "string"
    },
    "producer": {
      "default": "",
      "description": "Component or subsystem that produces/sends data",
      "title": "Producer",
      "type": "string"
    },
    "consumer": {
      "default": "",
      "description": "Component or subsystem that consumes/receives data",
      "title": "Consumer",
      "type": "string"
    },
    "signals": {
      "description": "Signal definitions within this interface",
      "items": {
        "$ref": "#/$defs/SignalDefinition"
      },
      "title": "Signals",
      "type": "array"
    },
    "timing_semantics": {
      "default": "",
      "description": "Timing behavior description (e.g., 'periodic', 'event-driven', 'on-change')",
      "title": "Timing Semantics",
      "type": "string"
    },
    "update_rate": {
      "default": "",
      "description": "Update rate or frequency (e.g., '50 Hz', 'on-demand')",
      "title": "Update Rate",
      "type": "string"
    },
    "fault_flags": {
      "description": "Fault/status flags associated with this interface",
      "items": {
        "type": "string"
      },
      "title": "Fault Flags",
      "type": "array"
    },
    "degradation_behavior": {
      "default": "",
      "description": "What happens when this interface degrades or fails",
      "title": "Degradation Behavior",
      "type": "string"
    },
    "related_requirements": {
      "description": "REQ-xxxx IDs related to this interface",
      "items": {
        "type": "string"
      },
      "title": "Related Requirements",
      "type": "array"
    },
    "related_functions": {
      "description": "FUNC-xxxx IDs related to this interface",
      "items": {
        "type": "string"
      },
      "title": "Related Functions",
      "type": "array"
    },
    "related_abnormals": {
      "description": "ABN-xxxx IDs related to this interface",
      "items": {
        "type": "string"
      },
      "title": "Related Abnormals",
      "type": "array"
    },
    "related_modes": {
      "description": "MODE-xxxx IDs of modes that monitor this interface",
      "items": {
        "type": "string"
      },
      "title": "Related Modes",
      "type": "array"
    },
    "related_guards": {
      "description": "GUARD-xxxx IDs of guards that reference signals from this interface",
      "items": {
        "type": "string"
      },
      "title": "Related Guards",
      "type": "array"
    }
  },
  "required": [
    "id",
    "name"
  ],
  "title": "Interface",
  "type": "object"
}