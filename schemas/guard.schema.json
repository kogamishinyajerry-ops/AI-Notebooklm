{
  "$defs": {
    "ArtifactType": {
      "description": "Valid artifact type identifiers.",
      "enum": [
        "requirement",
        "function",
        "interface",
        "abnormal",
        "glossary_entry",
        "trace_link",
        "mode",
        "transition",
        "guard"
      ],
      "title": "ArtifactType",
      "type": "string"
    },
    "AtomicPredicate": {
      "additionalProperties": false,
      "description": "A single comparison of a signal value against a threshold.\n\nExamples (in YAML):\n    predicate:\n      predicate_type: \"atomic\"\n      operator: \"gt\"\n      signal_ref: \"IFACE-0001.n2_speed\"\n      threshold: 95.0\n      unit: \"%\"\n\n    predicate:\n      predicate_type: \"atomic\"\n      operator: \"bool_true\"\n      signal_ref: \"IFACE-0002.fire_detected\"",
      "properties": {
        "predicate_type": {
          "const": "atomic",
          "default": "atomic",
          "description": "Discriminator: always 'atomic' for AtomicPredicate",
          "title": "Predicate Type",
          "type": "string"
        },
        "operator": {
          "$ref": "#/$defs/PredicateOperator",
          "description": "Comparison operator"
        },
        "signal_ref": {
          "description": "Signal reference in format IFACE-NNNN.signal_name",
          "title": "Signal Ref",
          "type": "string"
        },
        "threshold": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Comparison threshold (required for comparison ops, must be null for boolean ops)",
          "title": "Threshold"
        },
        "unit": {
          "default": "",
          "description": "Engineering unit of the threshold (e.g., '%', 'degC', 'rpm')",
          "title": "Unit",
          "type": "string"
        }
      },
      "required": [
        "operator",
        "signal_ref"
      ],
      "title": "AtomicPredicate",
      "type": "object"
    },
    "CompoundPredicate": {
      "additionalProperties": false,
      "description": "A boolean combination of predicates (AND/OR/NOT).\n\nExamples (in YAML):\n    predicate:\n      predicate_type: \"compound\"\n      combinator: \"and\"\n      operands:\n        - predicate_type: \"atomic\"\n          operator: \"gt\"\n          signal_ref: \"IFACE-0001.n2_speed\"\n          threshold: 95.0\n        - predicate_type: \"atomic\"\n          operator: \"lt\"\n          signal_ref: \"IFACE-0001.oil_pressure\"\n          threshold: 20.0\n          unit: \"psi\"",
      "properties": {
        "predicate_type": {
          "const": "compound",
          "default": "compound",
          "description": "Discriminator: always 'compound' for CompoundPredicate",
          "title": "Predicate Type",
          "type": "string"
        },
        "combinator": {
          "$ref": "#/$defs/PredicateCombinator",
          "description": "Boolean combinator"
        },
        "operands": {
          "description": "Operands (predicates) to combine",
          "items": {
            "discriminator": {
              "mapping": {
                "atomic": "#/$defs/AtomicPredicate",
                "compound": "#/$defs/CompoundPredicate"
              },
              "propertyName": "predicate_type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/AtomicPredicate"
              },
              {
                "$ref": "#/$defs/CompoundPredicate"
              }
            ]
          },
          "title": "Operands",
          "type": "array"
        }
      },
      "required": [
        "combinator",
        "operands"
      ],
      "title": "CompoundPredicate",
      "type": "object"
    },
    "InputSignalRef": {
      "additionalProperties": false,
      "description": "Convenience cross-reference to a signal used by this guard.\n\nThis is informational — the authoritative signal binding is in\n``predicate.signal_ref`` for each AtomicPredicate leaf.",
      "properties": {
        "interface": {
          "description": "IFACE-xxxx ID of the interface",
          "title": "Interface",
          "type": "string"
        },
        "signal": {
          "description": "Signal name within the interface",
          "title": "Signal",
          "type": "string"
        },
        "unit": {
          "default": "",
          "description": "Expected engineering unit",
          "title": "Unit",
          "type": "string"
        }
      },
      "required": [
        "interface",
        "signal"
      ],
      "title": "InputSignalRef",
      "type": "object"
    },
    "LifecycleStatus": {
      "description": "Artifact lifecycle status.",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "withdrawn"
      ],
      "title": "LifecycleStatus",
      "type": "string"
    },
    "PredicateCombinator": {
      "description": "Boolean combinators for compound predicates.",
      "enum": [
        "and",
        "or",
        "not"
      ],
      "title": "PredicateCombinator",
      "type": "string"
    },
    "PredicateOperator": {
      "description": "Comparison operators for atomic predicates.",
      "enum": [
        "gt",
        "ge",
        "lt",
        "le",
        "eq",
        "ne",
        "bool_true",
        "bool_false"
      ],
      "title": "PredicateOperator",
      "type": "string"
    },
    "Provenance": {
      "description": "Tracks how artifact content was produced and its review state.\n\nThis is central to APLH's knowledge governance: every piece of content\nmust declare its origin and confidence level so that reviewers can\nassess trustworthiness.",
      "properties": {
        "source_type": {
          "$ref": "#/$defs/ProvenanceSourceType",
          "description": "How this content was produced"
        },
        "source_refs": {
          "description": "List of source document references (document IDs, URLs, etc.)",
          "items": {
            "type": "string"
          },
          "title": "Source Refs",
          "type": "array"
        },
        "method": {
          "default": "",
          "description": "Description of the production method (e.g., 'extracted by Gemini 3.1 Pro from CCAR-33 §33.28')",
          "title": "Method",
          "type": "string"
        },
        "confidence": {
          "default": 0.5,
          "description": "Confidence level 0.0–1.0",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "reviewed_by": {
          "default": "",
          "description": "Reviewer identity (empty if not yet reviewed)",
          "title": "Reviewed By",
          "type": "string"
        },
        "review_date": {
          "default": "",
          "description": "ISO date of review (empty if not yet reviewed)",
          "pattern": "^(|[0-9]{4}-[0-9]{2}-[0-9]{2}(T[0-9]{2}:[0-9]{2}:[0-9]{2}(Z|[\\+\\-][0-9]{2}:[0-9]{2})?)?)$",
          "title": "Review Date",
          "type": "string"
        }
      },
      "required": [
        "source_type"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "ProvenanceSourceType": {
      "description": "How the artifact content was produced.",
      "enum": [
        "human_authored",
        "ai_extracted",
        "ai_inferred",
        "mixed",
        "reference"
      ],
      "title": "ProvenanceSourceType",
      "type": "string"
    },
    "ReviewStatus": {
      "description": "Review workflow status.",
      "enum": [
        "draft",
        "in_review",
        "reviewed",
        "frozen",
        "rejected"
      ],
      "title": "ReviewStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Guard condition artifact for propulsion control logic.",
  "properties": {
    "id": {
      "description": "Unique artifact ID (e.g., REQ-0001)",
      "title": "Id",
      "type": "string"
    },
    "artifact_type": {
      "$ref": "#/$defs/ArtifactType",
      "default": "guard",
      "description": "Must be 'guard'"
    },
    "version": {
      "default": "0.1.0",
      "description": "Semantic version of this artifact",
      "title": "Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/LifecycleStatus",
      "default": "draft",
      "description": "Lifecycle status"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance",
      "description": "Content provenance and confidence metadata"
    },
    "review_status": {
      "$ref": "#/$defs/ReviewStatus",
      "default": "draft",
      "description": "Review workflow status"
    },
    "tags": {
      "description": "Free-form tags for filtering/grouping",
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "created_at": {
      "description": "ISO 8601 creation timestamp",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[\\+\\-][0-9]{2}:[0-9]{2})?$",
      "title": "Created At",
      "type": "string"
    },
    "updated_at": {
      "description": "ISO 8601 last-updated timestamp",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[\\+\\-][0-9]{2}:[0-9]{2})?$",
      "title": "Updated At",
      "type": "string"
    },
    "notes": {
      "default": "",
      "description": "Free-text notes, assumptions, open questions",
      "title": "Notes",
      "type": "string"
    },
    "name": {
      "description": "Guard condition name",
      "title": "Name",
      "type": "string"
    },
    "description": {
      "default": "",
      "description": "Human-readable summary of the guard condition (NOT the machine-checkable authority — see §4.7)",
      "title": "Description",
      "type": "string"
    },
    "predicate": {
      "description": "Structured predicate: the sole machine-checkable authority for this guard condition (AtomicPredicate | CompoundPredicate)",
      "discriminator": {
        "mapping": {
          "atomic": "#/$defs/AtomicPredicate",
          "compound": "#/$defs/CompoundPredicate"
        },
        "propertyName": "predicate_type"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/AtomicPredicate"
        },
        {
          "$ref": "#/$defs/CompoundPredicate"
        }
      ],
      "title": "Predicate"
    },
    "input_signals": {
      "description": "Informational cross-references to signals used by predicates",
      "items": {
        "$ref": "#/$defs/InputSignalRef"
      },
      "title": "Input Signals",
      "type": "array"
    },
    "related_interfaces": {
      "description": "IFACE-xxxx IDs of interfaces referenced by this guard",
      "items": {
        "type": "string"
      },
      "title": "Related Interfaces",
      "type": "array"
    },
    "related_requirements": {
      "description": "REQ-xxxx IDs related to this guard condition",
      "items": {
        "type": "string"
      },
      "title": "Related Requirements",
      "type": "array"
    },
    "related_abnormals": {
      "description": "ABN-xxxx IDs related to this guard condition",
      "items": {
        "type": "string"
      },
      "title": "Related Abnormals",
      "type": "array"
    },
    "used_by_transitions": {
      "description": "TRANS-xxxx IDs that reference this guard",
      "items": {
        "type": "string"
      },
      "title": "Used By Transitions",
      "type": "array"
    }
  },
  "required": [
    "id",
    "name",
    "predicate"
  ],
  "title": "Guard",
  "type": "object"
}