{
  "mode": "yolo",
  "depth": "standard",
  "model_profile": "quality",
  "commit_docs": false,
  "search_gitignored": true,
  "workflow": {
    "research": false,
    "plan_check": true,
    "verifier": true,
    "auto_advance": true
  },
  "parallelization": {
    "enabled": true,
    "plan_level": true,
    "task_level": false,
    "skip_checkpoints": false,
    "max_concurrent_agents": 3,
    "min_plans_for_parallel": 2
  },
  "git": {
    "branching_strategy": "none"
  },
  "gates": {
    "confirm_project": false,
    "confirm_phases": false,
    "confirm_roadmap": false,
    "confirm_breakdown": false,
    "confirm_plan": false,
    "execute_next_plan": false,
    "issues_review": false,
    "confirm_transition": false
  },
  "review_gates": {
    "manual_model": "Opus 4.6",
    "manual_trigger_required": true,
    "gate_phases": ["14", "16", "18"]
  },
  "automation": {
    "control_plane": "Notion",
    "repo_truth": true,
    "pause_on_manual_review": true,
    "pause_on_manual_freeze_authority": true
  }
}
